# OpenAI (preferred for Ask refine — key stays server-side via Vite proxy)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Set true on the server when OPENAI_API_KEY is present (nginx /api/openai/status)
OPENAI_CONFIGURED=false
VITE_OPENAI_MODEL=gpt-4o-mini

# Ollama / llm-runtime fallback (VPS via Tailscale)
OLLAMA_URL=http://100.108.78.46:11434

# Prefer small CPU-friendly models — VPS currently has size_vram: 0
# Best latency on your box: phi3:mini (~7–8 tok/s warm)
# Avoid for Ask: qwen2.5:14b, mistral-nemo:12b, local qwen2.5-coder:32b
VITE_OLLAMA_MODEL=phi3:mini
